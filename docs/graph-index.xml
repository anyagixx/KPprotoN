  <CriticalFlows>
    <CF-001 NAME="Single-command VPS bootstrap">
      install.sh collects minimal input, installs Docker stack, provisions certs, writes env, and starts services.
    </CF-001>
    <CF-002 NAME="Email magic-link request">
      User submits email, system creates expiring token and calls Resend API with a verification link.
    </CF-002>
    <CF-003 NAME="Verification to proxy issuance">
      Token validation triggers user persistence in DETS, per-user SNI generation, policy update, and tg://proxy output.
    </CF-003>
    <CF-004 NAME="TLS and domain-fronting edge">
      Wildcard certificates, SNI routing, and HTTPS portal traffic must coexist safely on port 443.
    </CF-004>
    <CF-005 NAME="External integration failure handling">
      Resend auth/network errors and certificate provisioning failures must surface actionable operator and user feedback.
    </CF-005>
  </CriticalFlows>
