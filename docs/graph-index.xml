      <Supporting>Docker Compose on Ubuntu 22.04/24.04</Supporting>
      <Web> Cowboy HTTP server behind domain fronting on :443 </Web>
      <Persistence>DETS</Persistence>
    </Runtime>
    <TestingStack>
      <Tool>eunit or common_test</Tool>
